{
  "name": "@ddas/server",
  "version": "2.0.0-alpha.0",
  "description": "DDAS server: REST API, approval routing, SPA host, background jobs \u2014 one process + Postgres",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "node --watch dist/main.js",
    "start": "node dist/main.js",
    "openapi:write": "node dist/tools/write-openapi.js"
  },
  "dependencies": {
    "@ddas/audit": "workspace:*",
    "@ddas/blob": "workspace:*",
    "@ddas/db": "workspace:*",
    "@ddas/engine": "workspace:*",
    "@ddas/extraction": "workspace:*",
    "@ddas/policy": "workspace:*",
    "@ddas/routing": "workspace:*",
    "@fastify/cookie": "^11.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^9.1.1",
    "@fastify/swagger": "^9.5.0",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.4.0",
    "fastify-type-provider-zod": "^4.0.0",
    "pg": "^8.16.0",
    "pg-boss": "^10.3.0",
    "prom-client": "^15.1.0",
    "zod": "^3.24.0",
    "fastify-plugin": "^5.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "openid-client": "^6.1.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.828.0",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.15.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "yaml": "^2.7.0",
    "jose": "^5.9.0"
  }
}
