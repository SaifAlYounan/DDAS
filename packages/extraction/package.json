{
  "name": "@ddas/extraction",
  "version": "2.0.0",
  "description": "DDAS fact extraction: the only package that talks to an LLM. Produces cited fact sets, never tiers. Fail-closed: an ungroundable citation downgrades to NOT_FOUND.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ddas/engine": "workspace:*",
    "@ddas/policy": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
