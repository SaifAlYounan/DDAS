# DDAS configuration — copy to .env and fill in.
# Every secret is an environment variable. The database stores password and
# API-key hashes; webhook signing secrets are stored as-is (HMAC needs the
# recoverable secret to sign each delivery).

# Postgres (required)
DATABASE_URL=postgres://ddas:ddas@localhost:5432/ddas

# HTTP
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Document blob storage (content-addressed)
BLOB_DIR=/data/blobs

# Built web console. MUST be an ABSOLUTE path (@fastify/static rejects a
# relative root at boot). Leave unset to run API-only.
# WEB_DIST=/app/web

# First-boot admin (created only if no admin exists yet)
DDAS_ADMIN_EMAIL=admin@example.com
DDAS_ADMIN_PASSWORD=change-me-please

# LLM fact extraction — the ONLY place DDAS talks to a model.
# Provider: "anthropic", "openai-compatible" (vLLM, Ollama, Azure, ...),
# or "stub" (extracts nothing — every fact NOT_FOUND, for manual entry / trials)
DDAS_EXTRACTION_PROVIDER=anthropic
DDAS_EXTRACTION_MODEL=claude-sonnet-5
DDAS_EXTRACTION_API_KEY=
# Only for openai-compatible providers:
# DDAS_EXTRACTION_BASE_URL=http://localhost:11434/v1

# SSO (OIDC) — set all four to enable a "Sign in with SSO" button.
# OIDC_ISSUER_URL=https://idp.example.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URL=https://ddas.example.com/api/v1/auth/oidc/callback
# OIDC_DEFAULT_ROLES=requester        # roles for JIT-provisioned users (comma-separated)
# OIDC_ALLOW_INSECURE=false           # permit http:// issuers (labs/tests only)

# Webhook delivery worker tuning (optional; sensible defaults otherwise)
# WEBHOOK_POLL_MS=2000
# WEBHOOK_RETRY_BASE_MS=30000

# Rate limits — per route class, fixed window, Postgres-backed (limits hold
# across every app node sharing the database). Limit = max requests per
# window; 0 disables a class. /healthz and /metrics are never rate-limited.
# auth (login/OIDC, keyed per IP) — strictest; the in-memory per-email login
# limiter and the timing-oracle protections still apply underneath.
# RATE_LIMIT_AUTH_LIMIT=30
# RATE_LIMIT_AUTH_WINDOW_SEC=60
# mutation routes (POST/PUT/PATCH/DELETE, keyed per principal)
# RATE_LIMIT_MUTATION_LIMIT=120
# RATE_LIMIT_MUTATION_WINDOW_SEC=60
# read routes (GET, keyed per principal) — generous
# RATE_LIMIT_READ_LIMIT=600
# RATE_LIMIT_READ_WINDOW_SEC=60
# admin routes (everything under /api/v1/admin/ and /scim/v2, any method)
# RATE_LIMIT_ADMIN_LIMIT=120
# RATE_LIMIT_ADMIN_WINDOW_SEC=60
