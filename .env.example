# DDAS configuration — copy to .env and fill in.
# All secrets live in env vars; nothing secret is ever stored in the database
# except hashed API keys and encrypted webhook secrets.

# Postgres
DATABASE_URL=postgres://ddas:ddas@localhost:5432/ddas

# Extraction provider: "anthropic" or "openai-compatible" (vLLM, Ollama, Azure, ...)
DDAS_EXTRACTION_PROVIDER=anthropic
DDAS_EXTRACTION_MODEL=claude-sonnet-5
DDAS_EXTRACTION_API_KEY=
# Only for openai-compatible providers:
# DDAS_EXTRACTION_BASE_URL=http://localhost:11434/v1

# Encryption key for at-rest secrets (webhook secrets). 32 bytes, base64.
DDAS_ENCRYPTION_KEY=
