{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "env": [
        "TEST_DATABASE_URL",
        "DATABASE_URL",
        "TEST_S3_ENDPOINT",
        "TEST_S3_ACCESS_KEY_ID",
        "TEST_S3_SECRET_ACCESS_KEY"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {}
  }
}
